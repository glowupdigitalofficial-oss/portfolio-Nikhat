            .hero h1 {
                font-size: 2.5rem;
            }

            nav ul {
                gap: 1rem;
                font-size: 0.9rem;
            }

            .section-title {
                font-size: 2rem;
            }

            .highlights {
                grid-template-columns: 1fr;
            }

            .contact-info {
                gap: 1.5rem;
            }
        }
    </style>
